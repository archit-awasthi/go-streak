rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Habits collection
      match /habits/{habitId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Logs subcollection — strict date enforcement
        match /logs/{dateStr} {
          allow read: if request.auth != null && request.auth.uid == userId;

          // Only allow writing today's date (server-side anti-cheat)
          allow create, update: if
            request.auth != null &&
            request.auth.uid == userId &&
            // dateStr must match today's date at UTC
            dateStr == request.time.date().value &&
            // Only allow marking done=true (not un-marking)
            request.resource.data.done == true;

          // No deletions of individual log entries
          allow delete: if false;
        }
      }
    }
  }
}
